worker_processes 1;
events { worker_connections 1024; }
http {
    include      mime.types;
    default_type application/octet-stream;
    sendfile     on;
    server {
        listen      443 ssl;
        server_name _;
        ssl_certificate     {{ nginx_dir | replace('\\', '/') }}/ssl/server.crt;
        ssl_certificate_key {{ nginx_dir | replace('\\', '/') }}/ssl/server.key;
        ssl_protocols       TLSv1.2 TLSv1.3;
        ssl_ciphers         HIGH:!aNULL:!MD5;
        location / {
            root  html;
            index index.html;
        }
    }
}
